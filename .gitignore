# =============================================================================
# TinyKV Project .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea*
.vscode*
.cursor/
# Cursor stores rules, project state, and AI context here - keep out of version control

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# Go - Build & Binaries
# -----------------------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
# Test binary (go test -c)
*.test

# -----------------------------------------------------------------------------
# Go - Test & Coverage Artifacts
# -----------------------------------------------------------------------------
*.out
coverage.*
*.coverprofile
profile.cov

# -----------------------------------------------------------------------------
# Go - Workspace & Dependencies
# -----------------------------------------------------------------------------
go.work
go.work.sum
/vendor

# -----------------------------------------------------------------------------
# Project-Specific Build Outputs
# -----------------------------------------------------------------------------
node/node
unikv/unikv
bin/*
_tools

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Temporary & Cache
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.swp
*.swo
*~
.cache/
